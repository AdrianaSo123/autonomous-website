{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
        "title": {
            "type": "string"
        },
        "date": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
            "description": "YYYY-MM-DD format strictly required"
        },
        "slug": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
            "description": "Lowercase, kebab-case strictly required"
        },
        "tags": {
            "type": "array",
            "items": {
                "type": "string"
            }
        },
        "summary": {
            "type": "string"
        },
        "body": {
            "type": "string"
        }
    },
    "required": [
        "title",
        "date",
        "slug",
        "tags",
        "summary",
        "body"
    ],
    "additionalProperties": false
}
