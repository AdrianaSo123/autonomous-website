{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "personal_brand": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "tagline": {
          "type": "string"
        },
        "bio": {
          "type": "string"
        }
      },
      "required": [
        "name",
        "tagline",
        "bio"
      ],
      "additionalProperties": false
    },
    "services": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        },
        "required": [
          "title",
          "description"
        ],
        "additionalProperties": false
      }
    },
    "selected_works": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "link": {
            "type": "string"
          }
        },
        "required": [
          "title",
          "description",
          "link"
        ],
        "additionalProperties": false
      }
    },
    "philosophy": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "content": {
          "type": "string"
        }
      },
      "required": [
        "title",
        "content"
      ],
      "additionalProperties": false
    },
    "social_proof": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "source": {
            "type": "string"
          },
          "quote": {
            "type": "string"
          }
        },
        "required": [
          "source",
          "quote"
        ],
        "additionalProperties": false
      }
    },
    "connect_links": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "platform": {
            "type": "string"
          },
          "url": {
            "type": "string"
          }
        },
        "required": [
          "platform",
          "url"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "personal_brand",
    "services",
    "selected_works",
    "philosophy",
    "social_proof",
    "connect_links"
  ],
  "additionalProperties": false
}