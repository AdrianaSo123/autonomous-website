{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "array",
    "items": {
        "type": "object",
        "properties": {
            "title": {
                "type": "string"
            },
            "date": {
                "type": "string",
                "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
            },
            "slug": {
                "type": "string",
                "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
            },
            "tags": {
                "type": "array",
                "items": {
                    "type": "string"
                }
            }
        },
        "required": [
            "title",
            "date",
            "slug",
            "tags"
        ],
        "additionalProperties": false
    }
}